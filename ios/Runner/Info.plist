<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Petafinds</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>petafinds</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!--
		Google Sign-In URL scheme. The google_sign_in iOS plugin launches
		a URL with this custom scheme to open the Google account picker;
		iOS then routes the OAuth callback back to the app through the
		same scheme. Value is the REVERSED_CLIENT_ID from
		ios/Runner/GoogleService-Info.plist and must stay in sync with
		that file if Firebase regenerates the iOS OAuth client.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.263905072020-rhmdc4qm4f2gqe27hmcmjqaogbgk5qp5</string>
			</array>
		</dict>
	</array>
	<!--
		GIDClientID — Google Sign-In iOS SDK reads this at bootstrap to
		know which OAuth client to authenticate against. Without it the
		SDK has been observed to crash on TestFlight builds with an
		obscure keychain/config error (it works in dev because the SDK
		can sometimes infer the client id from the URL scheme, but
		release builds with stricter linker stripping fail). Mirror of
		the CLIENT_ID field in GoogleService-Info.plist; must stay in
		sync if Firebase regenerates the iOS OAuth client.
	-->
	<key>GIDClientID</key>
	<string>263905072020-rhmdc4qm4f2gqe27hmcmjqaogbgk5qp5.apps.googleusercontent.com</string>
	<!--
		Privacy purpose strings.

		Location: the map screen calls Geolocator.getCurrentPosition()
		to center the map on the user and to compute "shops near you"
		distances. We only request foreground access, but the geolocator
		iOS plugin's binary still references the Always-and-WhenInUse
		API surface, which is what Apple's automated review flags
		(ITMS-90683). All three location keys carry the same honest
		string so the runtime prompt + App Review reviewer both see a
		clear, accurate reason.

		Photo library + camera + microphone: image_picker is used in
		the business product form to attach product photos (gallery
		pick or fresh camera capture). Microphone is included because
		image_picker on iOS will request it the first time a video
		picker is opened, even if the app currently only picks stills —
		safer to declare now than ship a build that crashes on first
		video attempt later.
	-->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Petafinds uses your location to show nearby Pettah shops on the map and to surface businesses close to you.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Petafinds uses your location to show nearby Pettah shops on the map and to surface businesses close to you.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Petafinds uses your location to show nearby Pettah shops on the map and to surface businesses close to you.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Petafinds needs access to your photo library so you can attach photos to your business profile and product listings.</string>
	<key>NSCameraUsageDescription</key>
	<string>Petafinds uses the camera so you can take new photos of your products to attach to listings.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Petafinds requests microphone access only when you attach a video to a listing.</string>
</dict>
</plist>
