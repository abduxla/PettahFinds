rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Two valid admin signals, either grants admin:
    //   1) Custom claim `admin: true` set via Admin SDK / a trusted
    //      backend: admin.auth().setCustomUserClaims(uid, { admin: true }).
    //      Preferred — no extra Firestore read per rule eval.
    //   2) Firestore /users/{uid} doc with role == 'admin'. Pragmatic
    //      fallback so admins can be promoted via the Firebase console
    //      without standing up a backend just to flip claims. Costs one
    //      extra get() per admin-gated request — acceptable while the
    //      admin set is small.
    // Either bootstraps the in-app admin shell + grants the privileged
    // writes below.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // True if the given businessId doc exists and is owned by the caller.
    function ownsBusiness(businessId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/businesses/$(businessId))
        && get(/databases/$(database)/documents/businesses/$(businessId))
             .data.ownerUid == request.auth.uid;
    }

    // Fields a user is allowed to change on their own profile.
    function userSelfMutableFields() {
      return ['displayName', 'phoneNumber', 'photoUrl',
              'onboardingCompleted', 'businessId'];
    }

    // Fields a business owner is allowed to edit on their own business doc
    // (excludes isVerified, membershipTier, ratingAvg, ratingCount, ownerUid).
    function businessOwnerMutableFields() {
      return ['businessName', 'location', 'description', 'phone', 'email',
              'whatsappNumber', 'category', 'logoUrl', 'bannerUrl',
              'latitude', 'longitude'];
    }

    // ---------- Users ----------
    match /users/{uid} {
      // Users can read only their own profile. Admins can read any.
      allow read: if isOwner(uid) || isAdmin();

      // Create: only the authenticated user, and role must be 'user' or
      // 'business' (never 'admin' — that is set via custom claims only).
      allow create: if isOwner(uid)
                    && request.resource.data.role in ['user', 'business'];

      // Update: owner may only change non-privileged fields. role and any
      // other privileged field stay frozen for the client; admins can change
      // anything. businessId change is allowed only to a business the caller
      // actually owns.
      allow update: if isAdmin()
                    || (
                      isOwner(uid)
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(userSelfMutableFields())
                      && (
                        request.resource.data.businessId == resource.data.businessId
                        || request.resource.data.businessId == null
                        || request.resource.data.businessId == ''
                        || ownsBusiness(request.resource.data.businessId)
                      )
                    );

      // Self-delete (GDPR right-to-be-forgotten) and admin delete.
      // Owner-side deletion is the last step of the cascade in
      // AccountDeletionService.deleteSelf.
      allow delete: if isAdmin() || isOwner(uid);
    }

    // ---------- Businesses ----------
    match /businesses/{businessId} {
      // Three read paths:
      //   1. Verified listings — public (the customer directory).
      //   2. Admin — sees everything, including the review queue.
      //   3. Owner — sees their own listing even while unverified, so
      //      the merchant dashboard renders during the review wait.
      //
      // Note for list queries: Firestore evaluates this rule per-doc on
      // every result. A list query MUST narrow to docs the rule allows,
      // otherwise the query fails permission-denied. Customer screens
      // therefore use repository methods that filter on
      // `isVerified == true`; admin screens use the explicit admin
      // methods (`streamAllIncludingPending`, `streamPending`) which
      // pass via the isAdmin() branch.
      allow read: if resource.data.isVerified == true
                  || isAdmin()
                  || (
                    isSignedIn()
                    && resource.data.ownerUid == request.auth.uid
                  );

      // Create paths:
      //   1. Admin — may create a business for anyone. Used by the
      //      manual onboarding flow in the admin shell; ownerUid is
      //      typically the merchant's UID (looked up by email), and
      //      `createdByAdminUid` is stamped for audit. Verification
      //      may be pre-toggled here too.
      //   2. Self-signup — caller must stamp themselves as ownerUid and
      //      cannot pre-verify themselves. We deliberately do NOT check
      //      ratingAvg/ratingCount value here: the prior `== 0` check
      //      compared an int literal against the double 0.0 the model
      //      writes and Firestore rejected it with permission-denied
      //      on every self-signup. The update rule freezes ratings on
      //      owner edits, and any fake initial rating is overwritten by
      //      the bounded review aggregator within hours of real activity,
      //      so the security cost of dropping the check is negligible.
      allow create: if isAdmin()
                    || (
                      isSignedIn()
                      && request.resource.data.ownerUid == request.auth.uid
                      && request.resource.data.isVerified == false
                    );

      // Update paths:
      //   1. Admin — unrestricted.
      //   2. Owner — may edit profile fields only (no isVerified / tier /
      //      rating changes, ownerUid frozen).
      //   3. Any signed-in user — only when the diff is exactly the rating
      //      fields, AND the new average is in the valid 1..5 range, AND
      //      the count is incremented by exactly 1. Without these bounds
      //      anyone could pin a competitor at 0.0 / 0 reviews. The proper
      //      long-term fix is to move rating aggregation to a Cloud Function
      //      so clients don't touch these fields at all.
      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.ownerUid == request.auth.uid
                      && request.resource.data.ownerUid == resource.data.ownerUid
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(businessOwnerMutableFields())
                    )
                    || (
                      isSignedIn()
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(['ratingAvg', 'ratingCount'])
                      && request.resource.data.ratingAvg is number
                      && request.resource.data.ratingCount is int
                      && request.resource.data.ratingAvg >= 1.0
                      && request.resource.data.ratingAvg <= 5.0
                      && request.resource.data.ratingCount > resource.data.ratingCount
                      && request.resource.data.ratingCount <= resource.data.ratingCount + 1
                    );

      // Owner of the business may delete their own listing (drives the
      // self-delete cascade). Admins can delete any.
      allow delete: if isAdmin()
                    || (isSignedIn()
                        && resource.data.ownerUid == request.auth.uid);
    }

    // ---------- Categories ----------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- Products ----------
    match /products/{productId} {
      allow read: if true;

      // Create: only the owner of the referenced business.
      allow create: if ownsBusiness(request.resource.data.businessId)
                    && request.resource.data.businessId is string;

      // Update paths:
      //   1. Admin — unrestricted.
      //   2. Business owner — may edit any non-rating field. businessId is
      //      pinned so a product can't be reassigned to another business.
      //   3. Any signed-in user — only when the diff is exactly the rating
      //      fields, AND the new average is in the valid 1..5 range, AND
      //      the count is incremented by exactly 1. Mirrors the same
      //      bounded-bump path the businesses collection uses for its
      //      ratingAvg/ratingCount aggregator (see ProductReviewRepository
      //      ._bumpProductRating). Without these bounds anyone could pin a
      //      competitor's product at 0.0 / 0 reviews. The proper long-term
      //      fix is a Cloud Function so clients don't touch these fields.
      allow update: if isAdmin()
                    || (
                      ownsBusiness(resource.data.businessId)
                      && request.resource.data.businessId == resource.data.businessId
                    )
                    || (
                      isSignedIn()
                      && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(['ratingAvg', 'ratingCount'])
                      && request.resource.data.ratingAvg is number
                      && request.resource.data.ratingCount is int
                      && request.resource.data.ratingAvg >= 1.0
                      && request.resource.data.ratingAvg <= 5.0
                      && request.resource.data.ratingCount > resource.data.ratingCount
                      && request.resource.data.ratingCount <= resource.data.ratingCount + 1
                    );

      // Hard delete: admin OR the owning business (drives self-delete
      // cascade when the merchant wipes their account). The normal
      // "delete a product" flow remains soft-delete via update.
      allow delete: if isAdmin() || ownsBusiness(resource.data.businessId);
    }

    // ---------- Offers ----------
    match /offers/{offerId} {
      allow read: if true;
      allow create: if ownsBusiness(request.resource.data.businessId);
      allow update: if isAdmin()
                    || (
                      ownsBusiness(resource.data.businessId)
                      && request.resource.data.businessId == resource.data.businessId
                    );
      allow delete: if isAdmin() || ownsBusiness(resource.data.businessId);
    }

    // ---------- Reviews ----------
    match /reviews/{reviewId} {
      allow read: if true;

      // Create: caller must stamp themselves as the reviewer AND the
      // referenced business must actually exist. Prevents impersonation,
      // userId spoofing, and spam reviews against random / fake business
      // IDs that would otherwise pollute the collection. Comment is also
      // length-capped so a single doc can't blow up storage cost.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.businessId is string
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && (
                      !('comment' in request.resource.data.keys())
                      || (request.resource.data.comment is string
                          && request.resource.data.comment.size() <= 2000)
                    )
                    && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId));

      // No edits from clients. Moderation = admin; author can re-review by
      // submitting a new review (or via admin tooling).
      allow update: if isAdmin();
      // Delete: admin, the review's author (self-delete cascade), OR
      // the owner of the reviewed business (business-side cascade when
      // a merchant wipes their own account).
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid)
                    || ownsBusiness(resource.data.businessId);
    }

    // ---------- Product Reviews ----------
    // Per-product reviews. Sibling collection to /reviews (business
    // reviews). Same shape minus the businessId existence check — here
    // the existence check pins to the parent product instead.
    match /productReviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.productId is string
                    && request.resource.data.businessId is string
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && (
                      !('comment' in request.resource.data.keys())
                      || (request.resource.data.comment is string
                          && request.resource.data.comment.size() <= 2000)
                    )
                    && exists(/databases/$(database)/documents/products/$(request.resource.data.productId));

      allow update: if isAdmin();
      // Same three-path delete as /reviews: admin, review author, or
      // the owner of the business that owns the reviewed product.
      // The product-owner check has to fetch the product to read its
      // businessId because productReviews docs only carry productId
      // directly.
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid)
                    || (
                      isSignedIn()
                      && exists(/databases/$(database)/documents/products/$(resource.data.productId))
                      && ownsBusiness(
                          get(/databases/$(database)/documents/products/$(resource.data.productId)).data.businessId)
                    );
    }

    // ---------- Favorites ----------
    match /favorites/{favoriteId} {
      // Reads restricted to the favorite's owner. The `resource == null`
      // short-circuit is required because the toggle's pre-write `get`
      // hits a non-existent doc on the very first favorite tap, and
      // Firestore evaluates this rule even for missing docs — without it,
      // first-time favorite silently fails with permission-denied. For
      // existing docs the standard `userId == auth.uid` check applies, so
      // list queries (`where('userId', isEqualTo: uid)`) work normally.
      allow read: if isSignedIn()
                  && (
                    resource == null
                    || resource.data.userId == request.auth.uid
                  );

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn()
                    && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // ---------- Reports ----------
    match /reports/{reportId} {
      // Reports are for moderation — only the submitter and admins read.
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.userId == request.auth.uid);

      // `details` is user-supplied free text — cap to keep a single report
      // from blowing up storage / read cost.
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && (
                      !('details' in request.resource.data.keys())
                      || (request.resource.data.details is string
                          && request.resource.data.details.size() <= 2000)
                    )
                    && (
                      !('reason' in request.resource.data.keys())
                      || (request.resource.data.reason is string
                          && request.resource.data.reason.size() <= 200)
                    );

      allow update: if isAdmin();
      // Reporter may delete their own report (drives self-delete cascade).
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ---------- Conversations (in-app chat) ----------
    match /conversations/{conversationId} {
      // Only the customer or the seller listed on the doc can read/update.
      // The `resource == null` short-circuit is required because
      // `openConversation`'s pre-write `get` hits a non-existent doc on
      // the very first "Chat Seller" tap, and Firestore evaluates this
      // rule even for missing docs — without it, the customer's first
      // tap silently fails with permission-denied. For existing docs the
      // standard participantIds check applies, so both the customer's
      // list query (`where('customerId', isEqualTo: uid)`) and the
      // seller's (`where('sellerId', isEqualTo: uid)`) work normally
      // because every returned doc has the requester in participantIds.
      allow read: if isSignedIn()
                  && (
                    resource == null
                    || request.auth.uid in resource.data.participantIds
                  );

      // Customer side creates the doc. Caller must stamp themselves as
      // customerId and be a member of participantIds. participantIds must
      // contain both the customer and the seller, no one else.
      allow create: if isSignedIn()
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.participantIds is list
                    && request.resource.data.participantIds.size() == 2
                    && request.auth.uid in request.resource.data.participantIds
                    && request.resource.data.sellerId in request.resource.data.participantIds
                    && request.resource.data.sellerId != request.auth.uid
                    && request.resource.data.productId is string
                    && request.resource.data.businessId is string;

      // Either party may update the conversation. Frozen identity fields
      // (sellerId, customerId, productId, businessId) prevent a participant
      // from reassigning the thread. The list-equality check on
      // participantIds was dropped — those four scalar identity fields
      // already pin the thread, and list equality in rules can falsely
      // reject when the SDK normalizes array ordering during partial
      // updates.
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.participantIds
                    && request.resource.data.sellerId == resource.data.sellerId
                    && request.resource.data.customerId == resource.data.customerId
                    && request.resource.data.productId == resource.data.productId
                    && request.resource.data.businessId == resource.data.businessId;

      // Deletes: admin OR any participant (drives self-delete cascade
      // — when one side of a conversation wipes their account, the
      // whole thread goes with them so no orphaned context lingers).
      allow delete: if isAdmin()
                    || (isSignedIn()
                        && request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        function parentParticipants() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        }

        allow read: if isSignedIn() && request.auth.uid in parentParticipants();

        allow create: if isSignedIn()
                      && request.auth.uid in parentParticipants()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;

        // Messages are immutable from the client.
        allow update: if false;
        // Delete: admin OR any participant of the parent conversation
        // (self-delete cascade wipes the messages subcollection before
        // removing the conversation doc).
        allow delete: if isAdmin()
                      || (isSignedIn()
                          && request.auth.uid in parentParticipants());
      }
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      // Users can only read their own notifications.
      allow read: if isSignedIn()
                  && resource.data.userId == request.auth.uid;

      // Clients may stage notifications addressed to themselves (e.g. the
      // welcome message at sign-up). Cross-user notifications still require
      // a trusted backend (Cloud Functions / Admin SDK). Title + body are
      // length-capped so a self-mint can't be used to bloat the collection.
      allow create: if isAdmin()
                    || (
                      isSignedIn()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.title is string
                      && request.resource.data.title.size() <= 200
                      && request.resource.data.body is string
                      && request.resource.data.body.size() <= 1000
                    );

      // Users can mark their own notifications read, but not change userId
      // or the notification content.
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['read', 'readAt']);

      // Recipient may delete their own notifications (drives self-delete
      // cascade). Admin can delete any.
      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
