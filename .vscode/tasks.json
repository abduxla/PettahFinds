{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PetaFinds: Maintenance Check",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/maintenance_check.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true,
        "close": false
      },
      "problemMatcher": [],
      "detail": "Run the same checks as the weekly GitHub Action locally and write MAINTENANCE_REPORT.md"
    }
  ]
}
