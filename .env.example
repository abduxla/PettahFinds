# PetaFinds — local environment example.
# Copy to `.env` (which is git-ignored) and fill in real values, OR pass
# the variables directly via `--dart-define=KEY=VALUE` at build time.
#
# Nothing in the app reads `.env` directly today; this file exists so
# fresh checkouts know which secrets they need.

# Mapbox public access token (pk.*). Required for the map screen.
# Generate at https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=pk.replace_me

# Optional: Mapbox SECRET token (sk.*) used by the Android Gradle plugin
# only — must be in android/gradle.properties, not in source.
# Documented here for awareness; never commit.
# MAPBOX_DOWNLOADS_TOKEN=sk.replace_me

# Firebase API keys for the client SDKs are NOT secrets and live in
# `lib/firebase_options.dart` (generated by FlutterFire). Server-side
# admin keys (firebase-adminsdk-*.json) MUST stay out of the repo.
